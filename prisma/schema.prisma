generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  country            String
  language           String
  currency           String
  timezone           String
  businessType       String
  adminEmail         String
  userCount          Int      @default(0)
  maxUsers           Int      @default(10)
  subscriptionPlan   String   @default("FREE")
  subscriptionStatus String   @default("ACTIVE")
  features           String[]
  ssoEnabled         Boolean  @default(false)
  mfaRequired        Boolean  @default(false)
  deletedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users               User[]
  departments         Department[]
  employees           Employee[]
  attendanceRecords   AttendanceRecord[]
  leaveRequests       LeaveRequest[]
  payrollRecords      PayrollRecord[]
  okrRecords          OkrRecord[]
  performanceReviews  PerformanceReview[]
  customRoles         CustomRole[]
  apiKeys             ApiKey[]
  integrationSettings IntegrationSetting[]
  subscriptions       Subscription[]
  invoices            Invoice[]
  paymentMethods      PaymentMethod[]
  contracts           Contract[]
  anomalyAlerts       AnomalyAlert[]
  notificationSettings NotificationSetting[]
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String
  name               String
  phone              String?
  department         String?
  position           String?
  avatarUrl          String?
  role               String    @default("USER")
  tenantId           String
  twoFactorEnabled   Boolean   @default(false)
  isActive           Boolean   @default(true)
  lastPasswordChange DateTime?
  permissions        String[]  @default([])
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  employee Employee?

  @@index([tenantId])
}

model Department {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  managerId     String?
  employeeCount Int       @default(0)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name], name: "tenantId_name")
  @@index([tenantId])
}

model Employee {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String?   @unique
  employeeNumber  String
  name            String
  email           String
  department      String
  position        String
  hireDate        DateTime
  salary          Float
  employmentType  String
  status          String    @default("ACTIVE")
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  attendanceRecords  AttendanceRecord[]
  leaveRequests      LeaveRequest[]
  payrollRecords     PayrollRecord[]
  okrRecords         OkrRecord[]
  performanceReviews PerformanceReview[]
  contracts          Contract[]

  @@index([tenantId])
  @@index([tenantId, department])
}

model AttendanceRecord {
  id         String    @id @default(cuid())
  tenantId   String
  employeeId String
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  status     String    @default("NORMAL")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([tenantId, date])
}

model LeaveRequest {
  id         String    @id @default(cuid())
  tenantId   String
  employeeId String
  leaveType  String
  startDate  DateTime
  endDate    DateTime
  days       Float
  reason     String
  status     String    @default("PENDING")
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
}

model PayrollRecord {
  id                  String   @id @default(cuid())
  tenantId            String
  employeeId          String
  month               String
  baseSalary          Float    @default(0)
  overtimePay         Float    @default(0)
  bonus               Float    @default(0)
  mealAllowance       Float    @default(0)
  transportAllowance  Float    @default(0)
  nationalPension     Float    @default(0)
  healthInsurance     Float    @default(0)
  employmentInsurance Float    @default(0)
  incomeTax           Float    @default(0)
  localIncomeTax      Float    @default(0)
  totalEarnings       Float    @default(0)
  totalDeductions     Float    @default(0)
  netPay              Float    @default(0)
  status              String   @default("DRAFT")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, month])
}

model OkrRecord {
  id              String   @id @default(cuid())
  tenantId        String
  employeeId      String
  quarter         String
  objectives      Json
  overallProgress Float    @default(0)
  status          String   @default("IN_PROGRESS")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
}

model PerformanceReview {
  id           String   @id @default(cuid())
  tenantId     String
  employeeId   String
  reviewerId   String
  period       String
  scores       Json
  overallScore Float?
  feedback     String
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
}

model CustomRole {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  permissions String[]
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model ApiKey {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  prefix       String
  hash         String
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  requestCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([hash])
}

model IntegrationSetting {
  id        String   @id @default(cuid())
  tenantId  String
  provider  String
  isEnabled Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, provider], name: "tenantId_provider")
  @@index([tenantId])
}

model Subscription {
  id           String    @id @default(cuid())
  tenantId     String
  planId       String
  plan         String
  billingCycle String
  status       String    @default("ACTIVE")
  startDate    DateTime
  endDate      DateTime
  cancelledAt  DateTime?
  cancelReason String?
  amount       Float
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  amount      Float
  tax         Float         @default(0)
  totalAmount Float
  status      String        @default("PENDING")
  issuedAt    DateTime      @default(now())
  dueDate     DateTime
  paidAt      DateTime?
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  items  InvoiceItem[]

  @@index([tenantId])
}

model InvoiceItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  amount      Float

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model PaymentMethod {
  id        String   @id @default(cuid())
  tenantId  String
  type      String
  label     String
  last4     String
  expMonth  Int?
  expYear   Int?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Contract {
  id          String    @id @default(cuid())
  tenantId    String
  employeeId  String
  title       String
  content     String
  status      String    @default("PENDING")
  signedAt    DateTime?
  signatureData String?
  fileUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
}

model AnomalyAlert {
  id          String    @id @default(cuid())
  tenantId    String
  type        String
  severity    String
  message     String
  employeeId  String?
  metadata    Json?
  isDismissed Boolean   @default(false)
  dismissedAt DateTime?
  dismissedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model NotificationSetting {
  id          String  @id @default(cuid())
  tenantId    String
  userId      String
  emailAlerts Boolean @default(true)
  smsAlerts   Boolean @default(false)
  pushAlerts  Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, userId])
  @@index([tenantId])
}
